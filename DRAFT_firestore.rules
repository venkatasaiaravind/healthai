rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['user', 'admin'] &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500));
    }

    function isValidUserProfile(data) {
      return data.uid == request.auth.uid &&
             (!('age' in data) || data.age is number) &&
             (!('weightKg' in data) || data.weightKg is number) &&
             (!('heightCm' in data) || data.heightCm is number);
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.healthScore is number && data.healthScore >= 0 && data.healthScore <= 100;
    }

    function isValidOrder(data) {
      return data.userId == request.auth.uid &&
             data.items is list && data.items.size() > 0 &&
             data.totalAmount is number && data.totalAmount >= 0;
    }

    function isValidFoodLog(data) {
      return data.userId == request.auth.uid &&
             data.foodName is string && data.foodName.size() <= 100 &&
             data.calories is number && data.calories >= 0;
    }

    // --- Match Blocks ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isVerified() && isValidUser(incoming());
      allow update: if isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastLogin']) && isValidUser(incoming());
    }

    match /userProfiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && isValidUserProfile(incoming());
    }

    match /products/{productId} {
      allow list, get: if true;
      allow write: if isAdmin() && isValidProduct(incoming());
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidOrder(incoming());
      allow update: if isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'paymentStatus', 'updatedAt']);
    }

    match /foodLogs/{logId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isOwner(existing().userId);
      allow create: if isVerified() && isValidFoodLog(incoming());
      allow delete: if isOwner(existing().userId);
    }

    match /chatSessions/{sessionId} {
      allow list, get: if isOwner(existing().userId);
      allow create: if isVerified() && incoming().userId == request.auth.uid;
      allow update: if isOwner(existing().userId);
      allow delete: if isOwner(existing().userId);
    }

    match /analytics/{eventId} {
      allow create: if isSignedIn();
      allow list: if isAdmin();
    }
  }
}
